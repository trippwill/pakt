# Nullable scalar with nil value
nickname:str? = nil

# Nullable scalar with actual value
score:int? = 42

# Nullable atom with nil
role:|admin, user|? = nil

# Nullable atom with actual value
status:|active, inactive|? = active

# Nullable in composite context: list of nullable ints
sparse:[int?] = [1, nil, 3, nil, 5]

# Nullable composite types
config:{host:str, port:int}? = nil

# Nullable with various scalar types
maybe-flag:bool?     = nil
maybe-price:dec?     = 9.99
maybe-stamp:datetime? = nil
