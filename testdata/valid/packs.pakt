# Mixed assignment + pack document

app-name:str = 'midwatch'
region:str = 'us-east-1'
active:bool = true

# Bare atom values in a list pack
states:[|queued, running, done|] <<
    |queued
    |running
    |done

# Pack of structs
events:[{ts:ts, level:|info, warn, error|, msg:str}] <<
    { 2026-06-01T14:30:00Z, |info, 'starting worker' }
    { 2026-06-01T14:30:05Z, |warn, 'replica lag detected' }
    { 2026-06-01T14:30:07Z, |error, 'retry scheduled' }

# Map pack entries
metrics:<str ; int> <<
    'requests' ; 120
    'errors'   ; 3
    'retries'  ; 1

# Normal assignments after packs
build:(int, int, int) = (2, 14, 0)
owners:[str] = ['platform', 'sre']
